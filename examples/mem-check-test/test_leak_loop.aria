;; Test: memory leak inside loop body
;; Expected: WARN — allocation in loop body without free (leak per iteration)

(module "test_leak_loop"
  (func $main
    (result i32)
    (effects io mem div)
    (intent "Allocate inside a loop without freeing — leaks every iteration")
    (local mut $i i32 0)
    (loop $lp
      (if (ge.i32 $i 10)
        (then (br $lp))
        (else
          ;; This allocation leaks on every iteration
          (let %tmp (ptr i32) (alloc i32 4))
          (store.i32 %tmp $i)
          (set $i (add.i32 $i 1)))))
    (return 0)))
