;; Test: conditional free — pointer freed in only one branch
;; Expected: WARN — use of potentially freed pointer '%p'

(module "test_conditional_free"
  (func $main
    (param $flag i32)
    (result i32)
    (effects io mem)
    (intent "Free pointer in only one branch, then use it")
    (let %p (ptr i32) (alloc i32 4))
    (store.i32 %p 42)
    (if (eq.i32 $flag 1)
      (then (free %p))
      (else))
    ;; %p may or may not be freed — should warn
    (let %val i32 (load.i32 %p))
    (print "val = %d\n" %val)
    (return 0)))
