---
const year = new Date().getFullYear();
---
<footer class="border-t border-border mt-24">
  <div class="max-w-6xl mx-auto px-4 py-12 flex flex-col md:flex-row justify-between gap-8 text-sm text-muted">
    <div>
      <span class="font-mono font-bold text-accent">ARIA</span>
      <p class="mt-2">AI Representation for Instruction Architecture</p>
      <p class="mt-1">&copy; {year} John Avera. Apache 2.0 License.</p>
    </div>
    <div class="flex gap-8">
      <div class="flex flex-col gap-2">
        <span class="text-text font-medium">Project</span>
        <a href="/get-started" class="hover:text-text transition-colors">Get Started</a>
        <a href="/docs" class="hover:text-text transition-colors">Documentation</a>
        <a href="/contributing" class="hover:text-text transition-colors">Contributing</a>
      </div>
      <div class="flex flex-col gap-2">
        <span class="text-text font-medium">Community</span>
        <a href="https://github.com/jhavera/aria-clj" target="_blank" rel="noopener" class="hover:text-text transition-colors">GitHub</a>
        <a href="https://github.com/jhavera/aria-clj/discussions" target="_blank" rel="noopener" class="hover:text-text transition-colors">Discussions</a>
        <a href="/blog" class="hover:text-text transition-colors">Blog</a>
      </div>
    </div>
  </div>
</footer>
