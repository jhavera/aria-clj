---
const links = [
  { href: '/story', label: 'Story' },
  { href: '/what-is-aria', label: 'What is ARIA' },
  { href: '/get-started', label: 'Get Started' },
  { href: '/docs', label: 'Docs' },
  { href: '/contributing', label: 'Contributing' },
  { href: '/blog', label: 'Blog' },
];
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-mono font-bold text-xl text-accent tracking-wider">ARIA</a>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-6">
      {links.map(link => (
        <a href={link.href} class="text-sm text-muted hover:text-text transition-colors">{link.label}</a>
      ))}
      <a href="https://github.com/jhavera/aria-clj" target="_blank" rel="noopener" class="text-sm text-muted hover:text-text transition-colors flex items-center gap-1">
        GitHub
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="lg:hidden text-muted hover:text-text p-2" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-bg/95 backdrop-blur-md">
    <div class="px-4 py-4 flex flex-col gap-3">
      {links.map(link => (
        <a href={link.href} class="text-muted hover:text-text transition-colors py-1">{link.label}</a>
      ))}
      <a href="https://github.com/jhavera/aria-clj" target="_blank" rel="noopener" class="text-muted hover:text-text transition-colors py-1">GitHub</a>
    </div>
  </div>
</nav>

<div class="h-16"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
