---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const stages = [
  { label: 'Prompt', sub: 'Natural Language' },
  { label: 'AI Model', sub: 'Layer 1' },
  { label: 'ARIA-IR', sub: 'S-Expressions' },
  { label: 'aria-clj', sub: 'Layer 2' },
  { label: 'C99 / WASM / JVM', sub: 'Backend Targets' },
];
---
<div class={`flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-0 ${compact ? 'text-sm' : ''}`}>
  {stages.map((stage, i) => (
    <div class="flex items-center">
      <div class={`flex flex-col items-center px-4 ${compact ? 'py-2' : 'py-3'}`}>
        <span class={`font-mono font-semibold ${stage.label === 'ARIA-IR' || stage.label === 'aria-clj' || stage.label === 'C99 / WASM / JVM' ? 'text-accent' : 'text-text'}`}>
          {stage.label}
        </span>
        <span class="text-xs text-muted mt-0.5">{stage.sub}</span>
      </div>
      {i < stages.length - 1 && (
        <svg class="w-5 h-5 text-muted hidden sm:block flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      )}
    </div>
  ))}
</div>
